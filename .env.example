# ─────────────────────────────────────────────────────────
# The Compound Wellness — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to Git.
# ─────────────────────────────────────────────────────────

# ── STRIPE ───────────────────────────────────────────────
# Get these from dashboard.stripe.com > Developers > API Keys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
# Get this from Stripe > Developers > Webhooks (after adding endpoint)
STRIPE_WEBHOOK_SECRET=whsec_...

# ── AIRTABLE ─────────────────────────────────────────────
# Get API key from airtable.com/account (Personal Access Token)
# Get Base ID from airtable.com — open your base, click Help > API docs
# The base ID is the string starting with "app..."
AIRTABLE_API_KEY=pat...
AIRTABLE_BASE_ID=app...

# ── KLAVIYO ──────────────────────────────────────────────
# Get from klaviyo.com > Account > Settings > API Keys
KLAVIYO_API_KEY=pk_...
# List IDs found in Klaviyo > Lists — click a list, copy ID from URL
KLAVIYO_LIST_ID=XXXXXX           # main marketing list (all contacts)
KLAVIYO_BOOKINGS_LIST_ID=XXXXXX  # paid bookings segment
KLAVIYO_INQUIRIES_LIST_ID=XXXXXX # inquiry leads segment

# ── SENDGRID ─────────────────────────────────────────────
# Get from app.sendgrid.com > Settings > API Keys
SENDGRID_API_KEY=SG....
# The email address your emails come from (must be verified in SendGrid)
FROM_EMAIL=hello@thecompoundwellness.com
# Internal email to receive booking/inquiry notifications
INTERNAL_NOTIFY_EMAIL=adrienne@thecompoundwellness.com

# ── SERVER ───────────────────────────────────────────────
PORT=3000
